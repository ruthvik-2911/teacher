{
  "expo": {
    "name": "GOODSYNK ERP",
    "slug": "expoApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/1_20260423_125948_0000.png",
    "scheme": "expoapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goodsynk.erp"
    },
    "android": {
      "package": "com.goodsynk.erp",
      "versionCode": 1,
      "icon": "./assets/images/1_20260423_125948_0000.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/1_20260423_125948_0000.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0e24526-3b8b-4c3a-8e9b-36e1c32927fe"
      }
    },
    "owner": "ruthvik_2911"
  }
}
